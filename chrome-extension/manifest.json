{
  "manifest_version": 3,
  "name": "Article Collector",
  "version": "1.0",
  "description": "一键收藏文章到飞书多维表格",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["activeTab"],
  "host_permissions": ["http://127.0.0.1:5679/*"]
}
