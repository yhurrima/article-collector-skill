# AI 引擎配置
# AI_PROVIDER: anthropic / openai / local
AI_PROVIDER=anthropic

# 通用 OpenAI 兼容配置可使用 AI_API_KEY / AI_BASE_URL。
# Anthropic 兼容配置也可使用 ANTHROPIC_AUTH_TOKEN / ANTHROPIC_BASE_URL。
AI_API_KEY=your_api_key_here
AI_BASE_URL=
ANTHROPIC_AUTH_TOKEN=your_api_key_here
ANTHROPIC_BASE_URL=
AI_MODEL=your_model_name

# 飞书多维表格
FEISHU_BASE_APP_TOKEN=your_base_app_token
FEISHU_ARTICLES_TABLE_ID=your_articles_table_id
FEISHU_WEEKLY_TABLE_ID=your_weekly_table_id

# 飞书 IM 推送目标 (群聊 ID)
FEISHU_IM_CHAT_ID=your_chat_id
